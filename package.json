{
  "name": "neno",
  "version": "10.10.0",
  "description": "NENO is a note-taking app that helps you manage your personal knowledge garden.",
  "type": "module",
  "dependencies": {
    "@lexical/link": "0.44.0",
    "@lexical/react": "0.44.0",
    "buffer": "^6.0.3",
    "idb-keyval": "^6.2.1",
    "isomorphic-git": "^1.37.5",
    "lexical": "0.44.0",
    "monaco-editor": "^0.55.1",
    "prismjs": "^1.30.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.59.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.3.0",
    "jsdom": "29.0.2",
    "stylelint": "17.9.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.10",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.5"
  },
  "scripts": {
    "stylelint": "npx stylelint \"**/*.css\"",
    "test-intl": "node --test src/intl/test.node-test.mjs",
    "compile": "npx tsc",
    "unit-test": "npx vitest run --dir src",
    "integration-test": "npx playwright test tests/integration/*.spec.ts",
    "visual-regression-test": "npx playwright test tests/visual-regression/*.spec.ts",
    "update-snapshots": "npx playwright test tests/visual-regression/*.spec.ts --update-snapshots",
    "test": "npm run unit-test && npm run test-intl",
    "subwaytext-example": "npm run compile && node dist/lib/subwaytext/examples/example.js",
    "subwaytext-performance-test": "npm run compile && node dist/lib/subwaytext/examples/performance-test.js",
    "dev": "npx vite",
    "build": "npx tsc && npx vite build",
    "lint": "npx eslint src --report-unused-disable-directives && npx eslint tests --report-unused-disable-directives",
    "all-checks": "npm run stylelint && npm run lint && npm run test && npm run integration-test && npm run build",
    "all-checks-visual": "npm run all-checks && npm run visual-regression-test",
    "lint-fix": "npx eslint src --report-unused-disable-directives --fix && npx eslint tests --report-unused-disable-directives --fix",
    "version:major": "npm version major",
    "version:minor": "npm version minor",
    "version:patch": "npm version patch"
  },
  "author": "Sebastian",
  "license": "Apache License 2.0"
}
